# Copy this file to .env and fill in your real keys.
# .env is gitignored.

# --- Sentiment engine (Phase 1) ---
FINNHUB_KEY=
FINLIGHT_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=sfe/0.1 by yourusername
# SEC EDGAR is keyless but requires a descriptive User-Agent per their policy.
SEC_EDGAR_USER_AGENT=sfe/0.1 (your-email@example.com)

# --- Quantitative engine (Phase 2) ---
# yfinance needs no key; Polygon is optional.
POLYGON_API_KEY=

# --- Enrichment signals (Phase 3) ---
FRED_API_KEY=
UNUSUAL_WHALES_KEY=

# --- Meta-synthesis layer (Phase 4) ---
ANTHROPIC_API_KEY=

# --- Storage ---
# SQLite local default. Switch to postgresql://... when migrating.
SFE_DB_URL=sqlite:///./data/sfe.db
